---
layout: null
permalink: /blog/posts.json
---
{
  "generatedAt": {{ site.time | date_to_xmlschema | jsonify }},
  "posts": [
    {% for post in site.posts %}{
      "path": {{ post.url | relative_url | jsonify }},
      "title": {{ post.title | jsonify }},
      "category": {{ post.categories | first | default: "Uncategorized" | jsonify }},
      "tags": {{ post.tags | jsonify }},
      "date": {{ post.date | date_to_xmlschema | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
